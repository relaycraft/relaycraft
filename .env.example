# AI online eval (local)
# Copy to `.env` and fill real values.

# Required: choose one key name (both are supported by script)
OPENAI_API_KEY=
# LLM_API_KEY=

# Optional endpoint/model
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# Eval options
AI_EVAL_SUITES=all
AI_EVAL_CASE_LEVEL=basic
AI_EVAL_CASES_DIR=.github/evals
AI_EVAL_REPORT_PATH=ai_eval_report.json
AI_EVAL_USE_TOOLS=true
AI_EVAL_PASS_RATE_THRESHOLD=0.90
AI_EVAL_FAIL_ON_INFRA=false
AI_EVAL_MAX_RETRIES=1
