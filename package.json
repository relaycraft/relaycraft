{
  "name": "relaycraft",
  "private": true,
  "version": "1.1.1",
  "description": "AI-Native Web Traffic Debugging Tool",
  "homepage": "https://relaycraft.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/relaycraft/relaycraft"
  },
  "bugs": {
    "url": "https://github.com/relaycraft/relaycraft/issues"
  },
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "author": "RelayCraft Team",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "RELAYCRAFT_DEV=1 pnpm tauri dev --config '{\"productName\": \"RelayCraft Dev\", \"identifier\": \"com.beta.relaycraft.dev\", \"proxy_port\": 9091}'",
    "build": "pnpm gen:licenses && tsc && vite build",
    "check:i18n": "node scripts/check-i18n.js",
    "preview": "vite preview",
    "tauri": "python engine-core/build.py --sync && tauri",
    "test": "vitest",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check --apply src",
    "gen:licenses": "node scripts/generate-licenses.cjs",
    "release": "release-it",
    "translate-release:local": "node .github/scripts/translate_release.mjs",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "commitlint:edit": "commitlint --edit",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "~2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "consola": "^3.4.2",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.9",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.6",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@release-it/conventional-changelog": "^11.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.2",
    "postcss": "^8.5.14",
    "release-it": "^20.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
